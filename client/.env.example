# === Configurazione Frontend ===

# Modalità mock: "true" = usa un backend finto in memoria (nessun server richiesto).
# Mettila a "false" quando il backend di Ettore è pronto.
VITE_USE_MOCK=true

# URL base delle API. In sviluppo, con il proxy di Vite, lascia "/api".
# In produzione punta al backend reale, es. https://api.tuodominio.com
VITE_API_BASE_URL=/api
